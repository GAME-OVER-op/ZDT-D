/.gradle/
/application/.gradle/
/application/.kotlin/
/application/build/
/application/app/build/
/application/app/.cxx/

# Rust build outputs
/rust/target/

# Project output artifacts
/out/

# Generated assets
/application/app/src/main/assets/zdt_module.zip
/application/app/src/main/assets/module.prop

# Signing keys
/keystores/*.keystore
/keystores/*.jks
!/keystores/.gitkeep

