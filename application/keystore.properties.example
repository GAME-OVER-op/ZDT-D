# Необязательно. По умолчанию build.sh сам создаёт простой debug keystore с паролем android.
# Этот файл нужен только если хочешь переопределить путь/пароли вручную.
# Скопируй в keystore.properties и заполни своими значениями
storeFile=/absolute/path/to/your.jks
storePassword=change_me
keyAlias=release
keyPassword=change_me
